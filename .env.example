# Database (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js / NextAuth (v5 uses AUTH_SECRET)
AUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook endpoint: https://YOUR_DOMAIN/api/stripe/webhook — subscribe at least to:
# checkout.session.completed, checkout.session.async_payment_succeeded, payment_intent.succeeded,
# payment_intent.payment_failed, charge.refunded

# Resend — verify the sender domain in Resend. Use exactly one of these shapes (no extra JSON quotes):
#   booker@yourdomain.com
#   Happy Wanderers <bookings@yourdomain.com>
# Prefer Admin → Settings → "Resend from address" in production (stored in DB); it overrides EMAIL_FROM / RESEND_FROM.
# RESEND_FROM is an optional second env name if EMAIL_FROM is misread by the host.
# Leave both blank only if you want the built-in onboarding@resend.dev fallback (not for production).
# Until the domain is verified, Resend may only allow sending TO your Resend account email (admin alerts
# use System settings → Admin alert email — set that to your account email for testing, or verify the domain).
RESEND_API_KEY="re_..."
EMAIL_FROM="Happy Wanderers <bookings@yourdomain.com>"
# RESEND_FROM="hello@yourdomain.com"

# Vercel Blob (admin media uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Cron (optional — expire pending bookings)
CRON_SECRET="random-string"

# Sentry (error monitoring) — use NEXT_PUBLIC_SENTRY_DSN (not SENTRY_DSN); SDK reads this in server + client configs
NEXT_PUBLIC_SENTRY_DSN="https://...@....ingest.sentry.io/..."
# Optional overrides (otherwise VERCEL_ENV / NODE_ENV used)
SENTRY_ENVIRONMENT="development"
SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_RELEASE=""
# CI / upload source maps (Sentry webpack plugin — set in CI secrets)
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
# Safe test route: GET /api/sentry-test with header x-sentry-debug-secret
SENTRY_DEBUG_SECRET=""

# Seed (drizzle/seed.ts)
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="ChangeMe!123"
ADMIN_ALERT_EMAIL="ops@yourdomain.com"
STAFF_SEED_EMAIL="staff@example.com"
